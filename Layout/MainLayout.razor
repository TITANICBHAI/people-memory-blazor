@inherits LayoutComponentBase
@inject PinService PinService
@inject NavigationManager Nav

<div class="app-layout">
    <header class="app-header">
        <span class="app-logo">⬡</span>
        <span class="app-title">PEOPLE MEMORY</span>
        <div class="header-spacer"></div>
        <button class="header-btn" @onclick="LockApp" title="Lock">🔒 LOCK</button>
    </header>
    <main class="app-content" @onclick="RecordActivity">
        @Body
    </main>
</div>

@code {
    private void LockApp()
    {
        PinService.Lock();
        Nav.NavigateTo("/", true); // Force full reload to re-show PIN screen
    }

    private void RecordActivity() => PinService.RecordActivity();
}
