@page "/add"
@page "/edit/{Id}"
@inject PeopleService People
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_isEdit ? "Edit" : "Add") Person — People Memory</PageTitle>

@if (_person is null) { <p style="padding:20px;color:var(--text-muted)">Loading…</p> }
else
{
    <!-- Page header -->
    <div class="app-header" style="height:36px;position:sticky;top:0;z-index:60">
        <button class="back-btn" @onclick="Cancel">← @(_isEdit ? "PROFILE" : "DASHBOARD")</button>
        <span class="app-title" style="font-size:12px;letter-spacing:2px">@(_isEdit ? "EDIT PERSON" : "ADD PERSON")</span>
        <div class="header-spacer"></div>
        <div style="display:flex;gap:6px;padding-right:4px">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">CANCEL</button>
            <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@string.IsNullOrWhiteSpace(_person.Name)">💾 SAVE</button>
        </div>
    </div>

    <div class="form-wrap">

        <!-- Left sidebar: basic info + photo -->
        <div class="form-sidebar">

            <p class="section-divider">BASIC INFO</p>

            <!-- Photo -->
            <div class="field-group">
                <label class="field-label">PHOTO (OPTIONAL)</label>
                <div class="photo-wrap">
                    @if (!string.IsNullOrEmpty(_person.PhotoBase64))
                    { <img class="photo-preview" src="@_person.PhotoBase64" alt="photo" /> }
                    else
                    { <div class="photo-placeholder">👤</div> }
                    <div>
                        <InputFile OnChange="PhotoChanged" accept="image/*"
                                   style="display:none" id="photoInput" />
                        <label for="photoInput" class="btn btn-secondary btn-sm" style="cursor:pointer">UPLOAD</label>
                        @if (!string.IsNullOrEmpty(_person.PhotoBase64))
                        {
                            <button class="btn btn-ghost btn-sm" style="margin-left:4px" @onclick="() => _person.PhotoBase64 = null">CLEAR</button>
                        }
                        <p class="photo-info" style="margin-top:6px">JPG / PNG<br/>Stored locally</p>
                    </div>
                </div>
            </div>

            <!-- Name -->
            <div class="field-group">
                <label class="field-label">NAME *</label>
                <input class="field-input" type="text" placeholder="Full name…"
                       @bind="_person.Name" @bind:event="oninput" />
            </div>

            <!-- Tags -->
            <div class="field-group">
                <label class="field-label">TAGS</label>
                <div class="tags-editor">
                    @foreach (var tag in _person.Tags)
                    {
                        var t = tag;
                        <span class="tag-removable">
                            <span class="tag @TagClass(t)">@t</span>
                            <button class="tag-x" @onclick="() => RemoveTag(t)" title="Remove">×</button>
                        </span>
                    }
                </div>
                <div class="tags-add-row" style="margin-top:8px">
                    <select class="field-select" style="flex:1" @bind="_newTagPreset">
                        <option value="">-- preset --</option>
                        <option>Friend</option>
                        <option>Work</option>
                        <option>Family</option>
                        <option>Online</option>
                    </select>
                    <input class="field-input" type="text" placeholder="or type custom…"
                           @bind="_newTagCustom" @bind:event="oninput" />
                    <button class="btn btn-secondary btn-sm" @onclick="AddTag">ADD</button>
                </div>
            </div>

            <!-- Trust level -->
            <div class="field-group">
                <label class="field-label">TRUST LEVEL — @_person.TrustLevel / 10</label>
                <div class="range-wrap">
                    <input class="field-range" type="range" min="0" max="10" step="1"
                           value="@_person.TrustLevel"
                           @oninput="e => _person.TrustLevel = int.Parse(e.Value!.ToString()!)"
                           style="background: linear-gradient(to right, @TrustColor(_person.TrustLevel) @(_person.TrustLevel*10)%, var(--border) @(_person.TrustLevel*10)%)" />
                    <span class="range-val" style="color:@TrustColor(_person.TrustLevel)">@_person.TrustLevel</span>
                </div>
            </div>

        </div>

        <!-- Right panel: notes + dates -->
        <div class="form-main">

            <p class="section-divider">NOTES</p>

            <div class="field-group">
                <label class="field-label">DESCRIPTION / THOUGHTS</label>
                <textarea class="field-textarea" placeholder="Who is this person? General notes…"
                          @bind="_person.Description" @bind:event="oninput"></textarea>
            </div>

            <div class="field-group">
                <label class="field-label">LIKES</label>
                <textarea class="field-textarea" style="min-height:60px"
                          placeholder="Things they like, interests, hobbies…"
                          @bind="_person.Likes" @bind:event="oninput"></textarea>
            </div>

            <div class="field-group">
                <label class="field-label">DISLIKES</label>
                <textarea class="field-textarea" style="min-height:60px"
                          placeholder="Things they dislike, pet peeves…"
                          @bind="_person.Dislikes" @bind:event="oninput"></textarea>
            </div>

            <div class="field-group">
                <label class="field-label">THINGS TO REMEMBER</label>
                <textarea class="field-textarea"
                          placeholder="Important reminders, sensitive topics, key context…"
                          @bind="_person.ThingsToRemember" @bind:event="oninput"></textarea>
            </div>

            <div class="field-group">
                <label class="field-label">QUICK FACTS</label>
                <textarea class="field-textarea" style="min-height:60px"
                          placeholder="Job, city, how you know them, key facts…"
                          @bind="_person.QuickFacts" @bind:event="oninput"></textarea>
            </div>

            <p class="section-divider">IMPORTANT DATES</p>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
                <div class="field-group">
                    <label class="field-label">BIRTHDAY</label>
                    <input class="field-input" type="date"
                           value="@DateVal(_person.Birthday)"
                           @oninput="e => _person.Birthday = ParseDate(e.Value?.ToString())" />
                </div>
                <div class="field-group">
                    <label class="field-label">FIRST MET</label>
                    <input class="field-input" type="date"
                           value="@DateVal(_person.FirstMet)"
                           @oninput="e => _person.FirstMet = ParseDate(e.Value?.ToString())" />
                </div>
                <div class="field-group">
                    <label class="field-label">LAST MET</label>
                    <input class="field-input" type="date"
                           value="@DateVal(_person.LastMet)"
                           @oninput="e => _person.LastMet = ParseDate(e.Value?.ToString())" />
                </div>
                <div class="field-group">
                    <label class="field-label">NEXT MEETING</label>
                    <input class="field-input" type="date"
                           value="@DateVal(_person.NextMeeting)"
                           @oninput="e => _person.NextMeeting = ParseDate(e.Value?.ToString())" />
                </div>
            </div>

            <!-- Custom dates -->
            <div class="field-group">
                <label class="field-label">CUSTOM EVENTS / TIMELINE ENTRIES</label>
                @if (_person.CustomDates.Any())
                {
                    @foreach (var cd in _person.CustomDates)
                    {
                        var entry = cd;
                        <div class="date-entry">
                            <span class="date-entry-date">@entry.Date.ToString("dd MMM yyyy")</span>
                            <span class="date-entry-label">@entry.Label</span>
                            <button class="date-x" @onclick="() => RemoveCustomDate(entry.Id)" title="Remove">×</button>
                        </div>
                    }
                }
                <!-- Add new -->
                <div class="add-date-row">
                    <input class="date-input-sm" type="date" @bind="_newDate" />
                    <input class="field-input" type="text" placeholder="e.g. Helped with project…"
                           @bind="_newDateLabel" @bind:event="oninput" />
                    <button class="btn btn-secondary btn-sm" @onclick="AddCustomDate">ADD</button>
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    private Person? _person;
    private bool _isEdit => !string.IsNullOrEmpty(Id);

    private string _newTagPreset = "";
    private string _newTagCustom = "";
    private DateTime _newDate = DateTime.Today;
    private string _newDateLabel = "";

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit && Id is not null)
        {
            var existing = await People.GetByIdAsync(Id);
            // Shallow copy so edits don't mutate live data until Save
            _person = existing is not null ? Clone(existing) : new Person();
        }
        else
        {
            _person = new Person();
        }
    }

    private async Task Save()
    {
        if (_person is null || string.IsNullOrWhiteSpace(_person.Name)) return;
        await People.SaveAsync(_person);
        People.InvalidateCache();
        Nav.NavigateTo(_isEdit ? $"/person/{_person.Id}" : "/");
    }

    private void Cancel() =>
        Nav.NavigateTo(_isEdit ? $"/person/{Id}" : "/");

    private void AddTag()
    {
        var tag = (!string.IsNullOrWhiteSpace(_newTagCustom) ? _newTagCustom : _newTagPreset).Trim();
        if (!string.IsNullOrEmpty(tag) && !_person!.Tags.Any(t => t.Equals(tag, StringComparison.OrdinalIgnoreCase)))
            _person.Tags.Add(tag);
        _newTagCustom = ""; _newTagPreset = "";
    }

    private void RemoveTag(string tag) => _person!.Tags.Remove(tag);

    private void AddCustomDate()
    {
        if (!string.IsNullOrWhiteSpace(_newDateLabel))
        {
            _person!.CustomDates.Add(new PersonDate { Date = _newDate, Label = _newDateLabel });
            _newDateLabel = "";
        }
    }

    private void RemoveCustomDate(string id) =>
        _person!.CustomDates.RemoveAll(d => d.Id == id);

    private async Task PhotoChanged(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(ms);
        var b64 = Convert.ToBase64String(ms.ToArray());
        _person!.PhotoBase64 = $"data:{file.ContentType};base64,{b64}";
    }

    private static string DateVal(DateTime? d) => d.HasValue ? d.Value.ToString("yyyy-MM-dd") : "";
    private static DateTime? ParseDate(string? s) =>
        DateTime.TryParse(s, out var dt) ? dt : null;

    private static string TrustColor(int t) =>
        t <= 3 ? "var(--red)" : t <= 6 ? "var(--yellow)" : "var(--green)";

    private static string TagClass(string tag) => tag.ToLower() switch
    {
        "friend" => "tag-friend", "work" => "tag-work",
        "family" => "tag-family", "online" => "tag-online",
        _ => "tag-custom"
    };

    // Deep copy to avoid mutating cached data
    private static Person Clone(Person p) => new()
    {
        Id = p.Id, Name = p.Name, PhotoBase64 = p.PhotoBase64,
        Tags = new(p.Tags), TrustLevel = p.TrustLevel,
        Description = p.Description, Likes = p.Likes,
        Dislikes = p.Dislikes, ThingsToRemember = p.ThingsToRemember,
        QuickFacts = p.QuickFacts, Birthday = p.Birthday,
        FirstMet = p.FirstMet, LastMet = p.LastMet, NextMeeting = p.NextMeeting,
        CustomDates = p.CustomDates.Select(d => new PersonDate { Id = d.Id, Date = d.Date, Label = d.Label }).ToList(),
        CreatedAt = p.CreatedAt, UpdatedAt = p.UpdatedAt
    };
}
