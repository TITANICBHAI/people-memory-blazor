@page "/"
@inject PeopleService People
@inject NavigationManager Nav

<PageTitle>People Memory — Dashboard</PageTitle>

<!-- Toolbar -->
<div class="dashboard-toolbar">
    <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" type="search" placeholder="Search name, tags, notes, likes, dislikes…"
               value="@_query" @oninput="OnSearch" />
    </div>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/add")'>+ ADD PERSON</button>
</div>

<!-- Stats bar -->
<div class="stats-bar">
    <div class="stat"><span class="stat-n">@_all.Count</span> people</div>
    @{ var tagCounts = _all.SelectMany(p => p.Tags).GroupBy(t => t).OrderByDescending(g => g.Count()); }
    @foreach (var tg in tagCounts.Take(4))
    {
        <div class="stat"><span class="stat-n">@tg.Count()</span> @tg.Key</div>
    }
</div>

<!-- Tag filter -->
<div class="filter-bar">
    <button class="filter-chip @(_tagFilter == "" ? "active" : "")" @onclick='() => SetFilter("")'>ALL</button>
    @foreach (var tag in _all.SelectMany(p => p.Tags).Distinct().OrderBy(t => t))
    {
        var t = tag;
        <button class="filter-chip @(_tagFilter == t ? "active" : "")" @onclick="() => SetFilter(t)">@t.ToUpper()</button>
    }
</div>

<!-- Table -->
@if (!_loading && Rows.Any())
{
    <div class="table-wrap">
        <table class="unity-table">
            <thead>
                <tr>
                    <th @onclick='() => SortBy("Name")'>NAME @SortIcon("Name")</th>
                    <th @onclick='() => SortBy("Tags")'>TAGS @SortIcon("Tags")</th>
                    <th @onclick='() => SortBy("TrustLevel")'>TRUST @SortIcon("TrustLevel")</th>
                    <th @onclick='() => SortBy("LastMet")'>LAST MET @SortIcon("LastMet")</th>
                    <th @onclick='() => SortBy("NotesCount")'>NOTES @SortIcon("NotesCount")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Rows)
                {
                    <tr @onclick="() => Open(p.Id)">
                        <td>
                            <div class="cell-name">
                                @if (!string.IsNullOrEmpty(p.PhotoBase64))
                                { <img class="avatar" src="@p.PhotoBase64" alt="@p.Name" /> }
                                else
                                { <div class="avatar-initials">@p.Initials</div> }
                                <span class="name-text">@p.Name</span>
                            </div>
                        </td>
                        <td>
                            <div class="tags-wrap">
                                @foreach (var tag in p.Tags)
                                { <span class="tag @TagClass(tag)">@tag</span> }
                            </div>
                        </td>
                        <td>
                            <span class="trust-badge @TrustClass(p.TrustLevel)">@p.TrustLevel</span>
                        </td>
                        <td>
                            <span class="muted-date">@(p.LastMet.HasValue ? p.LastMet.Value.ToString("dd MMM yyyy") : "—")</span>
                        </td>
                        <td><span class="notes-chip">@p.NotesCount</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!_loading)
{
    <div class="empty-state">
        <div class="empty-icon">👤</div>
        @if (!string.IsNullOrWhiteSpace(_query) || !string.IsNullOrEmpty(_tagFilter))
        {
            <p class="empty-title">No results found</p>
            <p class="empty-sub">Try a different search term or filter.</p>
        }
        else
        {
            <p class="empty-title">No people added yet</p>
            <p class="empty-sub">Click <strong>+ ADD PERSON</strong> to start building your database.</p>
        }
    </div>
}

@code {
    private List<Person> _all     = new();
    private List<Person> _results = new();
    private string       _query   = "";
    private string       _tagFilter = "";
    private string       _sort    = "Name";
    private bool         _asc     = true;
    private bool         _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _all     = await People.GetAllAsync();
        _results = _all;
        _loading = false;
    }

    private IEnumerable<Person> Rows
    {
        get
        {
            var src = string.IsNullOrWhiteSpace(_query) ? _all : _results;
            if (!string.IsNullOrEmpty(_tagFilter))
                src = src.Where(p => p.Tags.Any(t => t.Equals(_tagFilter, StringComparison.OrdinalIgnoreCase))).ToList();
            return _sort switch
            {
                "TrustLevel"  => _asc ? src.OrderBy(p => p.TrustLevel)        : src.OrderByDescending(p => p.TrustLevel),
                "LastMet"     => _asc ? src.OrderBy(p => p.LastMet)           : src.OrderByDescending(p => p.LastMet),
                "NotesCount"  => _asc ? src.OrderBy(p => p.NotesCount)        : src.OrderByDescending(p => p.NotesCount),
                "Tags"        => _asc ? src.OrderBy(p => p.Tags.FirstOrDefault()) : src.OrderByDescending(p => p.Tags.FirstOrDefault()),
                _             => _asc ? src.OrderBy(p => p.Name)              : src.OrderByDescending(p => p.Name),
            };
        }
    }

    private async Task OnSearch(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        _results = string.IsNullOrWhiteSpace(_query)
            ? _all
            : await People.SearchAsync(_query);
    }

    private void SortBy(string col) { if (_sort == col) _asc = !_asc; else { _sort = col; _asc = true; } }
    private void SetFilter(string tag) => _tagFilter = tag;
    private void Open(string id) => Nav.NavigateTo($"/person/{id}");

    private RenderFragment SortIcon(string col) => builder =>
    {
        if (_sort != col) return;
        builder.AddMarkupContent(0, $"<span class='sort-icon'>{(_asc ? "▲" : "▼")}</span>");
    };

    private static string TrustClass(int t) => t <= 3 ? "trust-low" : t <= 6 ? "trust-mid" : "trust-high";
    private static string TagClass(string tag) => tag.ToLower() switch
    {
        "friend" => "tag-friend", "work" => "tag-work",
        "family" => "tag-family", "online" => "tag-online",
        _ => "tag-custom"
    };
}
