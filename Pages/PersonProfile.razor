@page "/person/{Id}"
@inject PeopleService People
@inject NavigationManager Nav

<PageTitle>@(_person?.Name ?? "Profile") — People Memory</PageTitle>

@if (_person is null)
{
    <p style="padding:20px;color:var(--text-muted)">Loading…</p>
}
else
{
    <!-- Hero section -->
    <div class="profile-hero">
        @if (!string.IsNullOrEmpty(_person.PhotoBase64))
        { <img class="profile-avatar" src="@_person.PhotoBase64" alt="@_person.Name" /> }
        else
        { <div class="profile-avatar-initials">@_person.Initials</div> }

        <div class="profile-info">
            <h1 class="profile-name">@_person.Name</h1>
            <div class="profile-tags tags-wrap">
                @foreach (var tag in _person.Tags)
                { <span class="tag @TagClass(tag)">@tag</span> }
            </div>
            <p class="trust-label">TRUST LEVEL — @_person.TrustLevel / 10</p>
            <div class="trust-track">
                <div class="trust-fill" style="width:@(_person.TrustLevel*10)%;background:@TrustColor(_person.TrustLevel)"></div>
            </div>
        </div>

        <div class="profile-actions">
            <button class="btn btn-secondary btn-sm" @onclick="Edit">✏ EDIT</button>
            <button class="btn btn-danger btn-sm" @onclick="() => _confirmDelete = true">🗑 DELETE</button>
            <button class="btn btn-ghost btn-sm" @onclick="Back">← BACK</button>
        </div>
    </div>

    <!-- Content grid -->
    <div class="profile-grid">

        <!-- Timeline -->
        <div class="info-section" style="grid-column:1/-1">
            <div class="section-head">📅 IMPORTANT DATES &amp; TIMELINE</div>
            <div class="section-body">
                @if (TimelineItems.Any())
                {
                    <div class="timeline">
                        @foreach (var item in TimelineItems)
                        {
                            <div class="timeline-item">
                                <div class="timeline-dot"></div>
                                <div class="timeline-date">@item.Date</div>
                                <div class="timeline-label">@item.Label</div>
                            </div>
                        }
                    </div>
                }
                else { <p class="section-empty">No dates recorded.</p> }
            </div>
        </div>

        <!-- Description -->
        @if (!string.IsNullOrWhiteSpace(_person.Description))
        {
            <div class="info-section">
                <div class="section-head">📝 DESCRIPTION</div>
                <div class="section-body"><p class="section-text">@_person.Description</p></div>
            </div>
        }

        <!-- Likes -->
        <div class="info-section">
            <div class="section-head">👍 LIKES</div>
            <div class="section-body">
                @if (string.IsNullOrWhiteSpace(_person.Likes))
                { <p class="section-empty">Nothing noted.</p> }
                else
                { <p class="section-text">@_person.Likes</p> }
            </div>
        </div>

        <!-- Dislikes -->
        <div class="info-section">
            <div class="section-head">👎 DISLIKES</div>
            <div class="section-body">
                @if (string.IsNullOrWhiteSpace(_person.Dislikes))
                { <p class="section-empty">Nothing noted.</p> }
                else
                { <p class="section-text">@_person.Dislikes</p> }
            </div>
        </div>

        <!-- Things to remember -->
        <div class="info-section">
            <div class="section-head">⚠ THINGS TO REMEMBER</div>
            <div class="section-body">
                @if (string.IsNullOrWhiteSpace(_person.ThingsToRemember))
                { <p class="section-empty">Nothing noted.</p> }
                else
                { <p class="section-text">@_person.ThingsToRemember</p> }
            </div>
        </div>

        <!-- Quick facts -->
        <div class="info-section">
            <div class="section-head">⚡ QUICK FACTS</div>
            <div class="section-body">
                @if (string.IsNullOrWhiteSpace(_person.QuickFacts))
                { <p class="section-empty">Nothing noted.</p> }
                else
                { <p class="section-text">@_person.QuickFacts</p> }
            </div>
        </div>

    </div>

    <!-- Delete confirmation -->
    @if (_confirmDelete)
    {
        <div class="confirm-overlay">
            <div class="confirm-box">
                <p class="confirm-title">Delete @_person.Name?</p>
                <p class="confirm-text">This will permanently remove all data for this person. This action cannot be undone.</p>
                <div class="confirm-btns">
                    <button class="btn btn-ghost btn-sm" @onclick="() => _confirmDelete = false">CANCEL</button>
                    <button class="btn btn-danger btn-sm" @onclick="Delete">DELETE</button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string Id { get; set; } = "";
    private Person? _person;
    private bool _confirmDelete = false;

    protected override async Task OnInitializedAsync() =>
        _person = await People.GetByIdAsync(Id);

    private IEnumerable<(string Date, string Label)> TimelineItems
    {
        get
        {
            var items = new List<(DateTime dt, string label)>();
            if (_person!.Birthday.HasValue)    items.Add((_person.Birthday.Value,    $"🎂 Birthday"));
            if (_person.FirstMet.HasValue)     items.Add((_person.FirstMet.Value,    $"👋 First Met"));
            if (_person.LastMet.HasValue)      items.Add((_person.LastMet.Value,     $"🤝 Last Met"));
            if (_person.NextMeeting.HasValue)  items.Add((_person.NextMeeting.Value, $"📅 Next Meeting"));
            foreach (var d in _person.CustomDates) items.Add((d.Date, d.Label));
            return items
                .OrderBy(i => i.dt)
                .Select(i => (i.dt.ToString("dd MMM yyyy"), i.label));
        }
    }

    private void Edit() => Nav.NavigateTo($"/edit/{Id}");
    private void Back() => Nav.NavigateTo("/");
    private async Task Delete()
    {
        await People.DeleteAsync(Id);
        People.InvalidateCache();
        Nav.NavigateTo("/");
    }

    private static string TrustColor(int t) => t <= 3 ? "var(--red)" : t <= 6 ? "var(--yellow)" : "var(--green)";
    private static string TagClass(string tag) => tag.ToLower() switch
    {
        "friend" => "tag-friend", "work" => "tag-work",
        "family" => "tag-family", "online" => "tag-online",
        _ => "tag-custom"
    };
}
