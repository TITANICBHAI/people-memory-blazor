@inject PinService PinService
@inject IJSRuntime JS

<div class="pin-screen">
    <div class="pin-container">
        <div class="pin-logo">⬡</div>
        <h1 class="pin-title">PEOPLE MEMORY</h1>
        <p class="pin-subtitle">@Subtitle</p>

        <!-- Dot indicators -->
        <div class="pin-dots">
            @for (int i = 0; i < 6; i++)
            {
                var filled = i < _input.Length ? "filled" : "";
                <div class="pin-dot @filled"></div>
            }
        </div>

        <p class="pin-error">@_error</p>

        <!-- Invisible input for physical keyboard -->
        <input @ref="_ref" type="password" inputmode="numeric" pattern="[0-9]*"
               maxlength="6" value="@_input"
               @oninput="OnInput" @onkeydown="OnKeyDown"
               class="pin-hidden-input" autocomplete="off" />

        <!-- Numpad -->
        <div class="pin-numpad">
            @foreach (var k in new[] { "1","2","3","4","5","6","7","8","9" })
            { <button class="pin-key" @onclick="() => PressKey(k)">@k</button> }
            <div class="pin-key pin-key-empty"></div>
            <button class="pin-key" @onclick='() => PressKey("0")'>0</button>
            <button class="pin-key pin-key-back" @onclick="Backspace">⌫</button>
        </div>

        <button class="pin-submit" disabled="@(_input.Length < 4)" @onclick="Submit">
            @(_isSetup ? (_isConfirm ? "CONFIRM PIN" : "SET PIN") : "UNLOCK")
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnUnlocked { get; set; }

    private string _input = "";
    private string _first = "";
    private bool   _isSetup   = false;
    private bool   _isConfirm = false;
    private string _error     = "";
    private ElementReference _ref;

    private string Subtitle => _isSetup
        ? (_isConfirm ? "CONFIRM YOUR PIN" : "CREATE A NEW PIN (4–6 DIGITS)")
        : "ENTER YOUR PIN TO CONTINUE";

    protected override async Task OnInitializedAsync()
    {
        _isSetup = !await PinService.IsPinSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first)
            await JS.InvokeVoidAsync("eval",
                "setTimeout(()=>document.querySelector('.pin-hidden-input')?.focus(),50)");
    }

    private void OnInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? "";
        if (v.Length <= 6 && v.All(char.IsDigit))
        { _input = v; _error = ""; }
        if (_input.Length == 6) InvokeAsync(Submit);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    { if (e.Key == "Enter") InvokeAsync(Submit); }

    private void PressKey(string k)
    {
        if (_input.Length >= 6) return;
        _input += k; _error = "";
        if (_input.Length == 6) InvokeAsync(Submit);
    }

    private void Backspace()
    { if (_input.Length > 0) _input = _input[..^1]; }

    private async Task Submit()
    {
        if (_input.Length < 4) return;

        if (_isSetup)
        {
            if (!_isConfirm) { _first = _input; _input = ""; _isConfirm = true; }
            else if (_input == _first)
            { await PinService.SetPinAsync(_input); await OnUnlocked.InvokeAsync(); }
            else
            { _error = "PINs do not match. Try again."; _input = ""; _first = ""; _isConfirm = false; }
        }
        else
        {
            if (await PinService.VerifyPinAsync(_input)) { await OnUnlocked.InvokeAsync(); }
            else { _error = "Incorrect PIN. Try again."; _input = ""; }
        }
        StateHasChanged();
    }
}
