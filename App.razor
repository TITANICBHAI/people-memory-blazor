@inject PinService PinService

@if (!_unlocked)
{
    <PinLock OnUnlocked="HandleUnlocked" />
}
else
{
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <p style="padding:20px;color:#808080">Page not found.</p>
        </NotFound>
    </Router>
}

@code {
    private bool _unlocked;

    protected override async Task OnInitializedAsync()
    {
        var pinSet = await PinService.IsPinSetAsync();
        // If no PIN has been set yet, show the setup screen (PinLock handles both modes)
        _unlocked = !pinSet ? false : PinService.IsUnlocked;
    }

    private void HandleUnlocked()
    {
        _unlocked = true;
        StateHasChanged();
    }
}
